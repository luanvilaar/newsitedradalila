# ============================================
# DT - Dra. Dalila Lucena Medical Dashboard
# Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in the values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (Chat Assistant) ---
OPENAI_API_KEY=sk-proj-your-openai-key

# --- Google (Gemini + Maps) ---
GOOGLE_GEMINI_API_KEY=your-gemini-key
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-maps-key

# --- Replicate (Image Generation) ---
REPLICATE_API_TOKEN=your-replicate-token

# --- Avisa WhatsApp API ---
AVISA_API_BASE_URL=https://www.avisaapi.com.br/api
AVISA_API_TOKEN=your-avisa-token
AVISA_API_INSTANCE_ID=default
AVISA_API_SEND_PATH=/actions/sendMessage
AVISA_WEBHOOK_SECRET=your-webhook-secret
AVISA_WEBHOOK_URL=https://your-domain.com/api/webhooks/avisa
