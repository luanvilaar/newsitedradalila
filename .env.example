# ============================================
# DT - Dra. Dalila Lucena Medical Dashboard
# Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in the values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (Chat Assistant) ---
OPENAI_API_KEY=sk-proj-your-openai-key

# --- Google (Gemini + Maps) ---
GOOGLE_GEMINI_API_KEY=your-gemini-key
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-maps-key

# --- Replicate (Image Generation) ---
REPLICATE_API_TOKEN=your-replicate-token

# --- Avisa WhatsApp API ---
AVISA_API_BASE_URL=https://www.avisaapi.com.br/api
AVISA_API_TOKEN=your-avisa-token
AVISA_API_INSTANCE_ID=default
AVISA_API_SEND_PATH=/actions/sendMessage
AVISA_WEBHOOK_SECRET=your-webhook-secret
AVISA_WEBHOOK_URL=https://your-domain.com/api/webhooks/avisa

# --- Segurança: Criação de Conta de Médico ---
# Gere com: openssl rand -hex 32
# Obrigatório para usar /api/auth/register-doctor
DOCTOR_CREATION_SECRET=your-doctor-creation-secret

# --- NFS-e (Nota Fiscal de Serviços Eletrônica) ---
# Provedor: joao_pessoa_prefeitura_nuvemfiscal | joao_pessoa_prefeitura | nuvemfiscal
NFE_PROVIDER=joao_pessoa_prefeitura_nuvemfiscal
NFE_JP_BASE_URL=https://api.nuvemfiscal.com.br
NFE_JP_EMIT_PATH=/nfse
# OBRIGATORIO: nunca use fallback hardcoded — configure aqui ou nas vars do servidor
NFE_API_CLIENT_ID=your-nfe-client-id
NFE_API_KEY=your-nfe-api-key
# Dados do prestador
NFE_JP_PRESTADOR_CNPJ=00.000.000/0000-00
NFE_JP_PRESTADOR_INSCRICAO_MUNICIPAL=000000
NFE_JP_PRESTADOR_RAZAO_SOCIAL=Nome da Empresa Ltda
# Configuracoes tributarias
NFE_JP_ALIQUOTA=0.05
NFE_JP_NATUREZA_OPERACAO=1
NFE_JP_REGIME_ESPECIAL_TRIBUTACAO=0
NFE_JP_OPTANTE_SIMPLES_NACIONAL=false
NFE_JP_INCENTIVO_FISCAL=false
NFE_JP_ITEM_LISTA_SERVICO=
NFE_JP_CODIGO_TRIBUTACAO_MUNICIPIO=
NFE_JP_AMBIENTE=producao
